    "express": "^5.2.1",
    "uuid": "^14.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "concurrently": "^10.0.0",
    "vite": "^8.0.14",
    "vue": "^3.5.35"
  }
}
