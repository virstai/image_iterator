{
  "name": "image-iterator",
  "version": "1.0.0",
  "description": "Iterative image prompt builder using Ollama and ComfyUI",
  "main": "server.js",
  "scripts": {
    "start":      "node server.js",
    "server:dev": "node --watch server.js",
